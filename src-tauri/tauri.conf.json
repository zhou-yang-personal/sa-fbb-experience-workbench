{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SA FBB Experience Workbench",
  "version": "1.0.28",
  "identifier": "com.zhouyang.sa-fbb-experience-workbench",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SA FBB Experience Workbench",
        "width": 1440,
        "height": 900,
        "minWidth": 1280,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all"
  }
}
